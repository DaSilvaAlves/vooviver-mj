---
// FR-03: Destinos em Destaque — Premium glass cards
import destinations from '../data/destinations.json';

const unsplashImages: Record<string, string> = {
  'socotra':       'https://images.unsplash.com/photo-1547471080-7cc2caa01a7e?w=900&q=85',
  'uganda-ruanda': 'https://images.unsplash.com/photo-1516426122078-c23e76319801?w=900&q=85',
  'marrocos':      'https://images.unsplash.com/photo-1539020140153-e479b8c22e70?w=900&q=85',
  'tailandia':     'https://images.unsplash.com/photo-1528181304800-259b08848526?w=900&q=85',
};
---

<section id="destinos" class="py-20 md:py-28" aria-label="Destinos em destaque" style="background:#06060B;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="reveal text-center mb-16">
      <span class="gold-line" style="display:block;width:48px;height:3px;background:linear-gradient(90deg,#F5A623,rgba(245,166,35,0.3));border-radius:2px;margin:0 auto 1rem;"></span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black text-text leading-tight tracking-tight">
        Destinos que desafiam<br/>
        <span style="color:#F5A623;">o convencional</span>
      </h2>
      <p class="mt-4 text-lg max-w-2xl mx-auto" style="color:#8892A4;">
        Viagens de grupo com líder, guia local e voos incluídos. Preços que não encontras em mais nenhuma agência.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {destinations.map((dest, i) => (
        <article
          class={`reveal reveal-delay-${(i % 4) + 1} glass-card glass-card-hover overflow-hidden group`}
        >
          <!-- Image -->
          <div class="relative h-56 sm:h-64 overflow-hidden rounded-t-2xl">
            <img
              src={unsplashImages[dest.slug] || ''}
              alt={`Paisagem de ${dest.name} — destino VooViver`}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              width="900"
              height="500"
              loading="lazy"
              decoding="async"
            />
            <!-- Gradient overlay on image -->
            <div class="absolute inset-0" style="background:linear-gradient(to top, rgba(6,6,11,0.85) 0%, rgba(6,6,11,0.4) 50%, rgba(6,6,11,0.1) 100%);"></div>

            <!-- Badges on image -->
            <div class="absolute top-4 left-4 flex gap-2 flex-wrap">
              <span class="badge badge-teal">{dest.badge}</span>
              {dest.exclusive && (
                <span class="badge badge-purple">Exclusivo PT</span>
              )}
            </div>

            <!-- Price overlay on bottom of image -->
            <div class="absolute bottom-4 left-4 right-4">
              <p class="font-mono font-bold text-3xl leading-none" style="color:#F5A623;">
                {dest.priceFrom.toLocaleString('pt-PT')} <span class="text-lg">EUR</span>
              </p>
              <p class="text-xs mt-0.5" style="color:rgba(240,240,245,0.6);">/pessoa · com voos</p>
            </div>
          </div>

          <!-- Card body -->
          <div class="p-6">
            <h3 class="text-xl font-black text-text">{dest.name}</h3>
            <p class="text-sm mt-1" style="color:#8892A4;">Grupo organizado · guia local · alojamento incluído</p>

            <a
              href={`?destino=${dest.slug}#formulario`}
              class="btn-teal mt-5 w-full"
            >
              {dest.ctaDestino}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="reveal mt-12 text-center">
      <p class="text-sm" style="color:#8892A4;">
        Não encontras o destino que queres?
        <a href="https://wa.me/351933096770" target="_blank" rel="noopener noreferrer" class="font-semibold transition-colors" style="color:#00D4AA;">
          Fala directamente com a Maria
        </a>
      </p>
    </div>

  </div>
</section>
