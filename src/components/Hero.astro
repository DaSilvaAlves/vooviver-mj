---
// FR-01: Hero Section — Cinematic Dark Expedition with real photo
import mariaPhoto from '../assets/maria-jose-sequeira.png';
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden" aria-label="Apresentacao VooViver">

  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=1920&q=85"
      alt=""
      class="w-full h-full object-cover"
      width="1920"
      height="1080"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <!-- Cinematic overlay -->
    <div class="hero-overlay absolute inset-0"></div>
    <!-- Bottom vignette for section blending -->
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-bg to-transparent"></div>
    <!-- Subtle grain texture -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image:url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22200%22 height=%22200%22><filter id=%22n%22><feTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22/><feColorMatrix type=%22saturate%22 values=%220%22/></filter><rect width=%22200%22 height=%22200%22 filter=%22url(%23n)%22 opacity=%221%22/></svg>');background-size:200px 200px;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
    <div class="flex flex-col md:flex-row items-center md:items-start gap-10 md:gap-16">

      <!-- Text column -->
      <div class="flex-1 text-center md:text-left max-w-2xl mx-auto md:mx-0">

        <!-- Pre-headline badge -->
        <div class="animate-fade-in inline-flex items-center gap-2 mb-6">
          <span class="badge badge-gold">Sair da Caixa Viagens</span>
          <span class="badge badge-teal">VooViver Consultora Certificada</span>
        </div>

        <!-- Main headline -->
        <h1 class="animate-fade-in-up animation-delay-200 text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-heading font-black text-text leading-[1.05] tracking-tight">
          Sair da Caixa<br/>
          <span class="text-gradient-gold">Viagens de grupo</span><br/>
          <span style="color:#F0F0F5;">desde </span><span style="color:#00D4AA;">870 EUR</span>
        </h1>

        <p class="animate-fade-in-up animation-delay-400 mt-6 text-lg sm:text-xl leading-relaxed" style="color:#8892A4;">
          Destinos que nao encontras em mais nenhuma agencia — com <strong style="color:#F0F0F5;">voos, guia e lider incluidos.</strong>
        </p>

        <!-- CTAs -->
        <div class="animate-fade-in-up animation-delay-600 mt-8 flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href="#formulario" class="btn-primary glow-gold">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
            </svg>
            Pedir Orcamento Gratuito
          </a>
          <a
            href="https://wa.me/351933096770"
            target="_blank"
            rel="noopener"
            class="btn-whatsapp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Falar por WhatsApp
          </a>
        </div>

        <!-- Social links -->
        <div class="animate-fade-in-up animation-delay-800 mt-6 flex items-center gap-4 justify-center md:justify-start">
          <a href="https://www.instagram.com/sairdacaixa.viagens/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm transition-colors hover:opacity-80" style="color:#8892A4;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            @sairdacaixa.viagens
          </a>
          <a href="https://www.facebook.com/mariajose.sequeira.5" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-sm transition-colors hover:opacity-80" style="color:#8892A4;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
          <a href="https://www.linkedin.com/in/maria-jos%C3%A9-sequeira-58a81b48/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-sm transition-colors hover:opacity-80" style="color:#8892A4;">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>

        <!-- Trust micro-signals -->
        <div class="animate-fade-in-up animation-delay-800 mt-6 flex flex-wrap gap-5 justify-center md:justify-start">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 flex-shrink-0" style="color:#00D4AA;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm" style="color:#8892A4;">RNAVT N.12366</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 flex-shrink-0" style="color:#F5A623;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <span class="text-sm" style="color:#8892A4;">Viagens de grupo com lider</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 flex-shrink-0" style="color:#F5A623;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-sm" style="color:#8892A4;">Resposta em 24h</span>
          </div>
        </div>
      </div>

      <!-- Maria floating card with real photo -->
      <div class="animate-fade-in animation-delay-400 flex-shrink-0">
        <div class="glass-card p-6 text-center w-72" style="border-color:rgba(245,166,35,0.15);">
          <!-- Avatar with gold ring and real photo -->
          <div class="relative mx-auto w-28 h-28 mb-4">
            <div class="absolute inset-0 rounded-full glow-gold" style="background:conic-gradient(#F5A623 0%, rgba(245,166,35,0.3) 100%);padding:3px;border-radius:50%;">
              <img
                src={mariaPhoto.src}
                alt="Maria Jose Sequeira — Consultora VooViver"
                class="w-full h-full rounded-full object-cover"
                width="112"
                height="112"
                loading="eager"
              />
            </div>
          </div>

          <p class="font-black text-lg text-text">Maria Jose Sequeira</p>
          <p class="font-mono text-xs mt-1" style="color:#F5A623;">Consultora VooViver</p>

          <div class="mt-4 pt-4" style="border-top:1px solid rgba(255,255,255,0.06);">
            <div class="grid grid-cols-2 gap-3 text-center">
              <div>
                <p class="font-mono font-bold text-xl" style="color:#F5A623;">4</p>
                <p class="text-xs" style="color:#8892A4;">Destinos exclusivos</p>
              </div>
              <div>
                <p class="font-mono font-bold text-xl" style="color:#00D4AA;">870 EUR</p>
                <p class="text-xs" style="color:#8892A4;">Desde /pessoa</p>
              </div>
            </div>
          </div>

          <div class="mt-4">
            <a
              href="https://www.instagram.com/sairdacaixa.viagens/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-xs font-medium transition-colors"
              style="color:#8892A4;"
            >
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              @sairdacaixa.viagens
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 animate-fade-in animation-delay-800">
    <div class="flex flex-col items-center gap-2 opacity-50">
      <span class="text-xs font-mono tracking-widest uppercase" style="color:#8892A4;">Explorar</span>
      <svg class="w-5 h-5" style="color:#F5A623;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>
