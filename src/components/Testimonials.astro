---
// FR-05: Testemunhos — glass cards dark
import testimonials from '../data/testimonials.json';

const hasTestimonials = testimonials.length > 0;
---

{hasTestimonials ? (
  <section id="testemunhos" class="py-20 md:py-28" aria-label="Testemunhos de clientes" style="background:#06060B;">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="reveal text-center mb-16">
        <span style="display:block;width:48px;height:3px;background:linear-gradient(90deg,#F5A623,rgba(245,166,35,0.3));border-radius:2px;margin:0 auto 1rem;"></span>
        <h2 class="text-3xl sm:text-4xl font-black text-text">O que dizem os viajantes</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t: { text: string; name: string; destination: string; date: string }, i: number) => (
          <article class={`reveal reveal-delay-${i + 1} glass-card glass-card-hover p-6`}>
            <!-- Stars -->
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4" style="color:#F5A623;" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <blockquote class="text-base leading-relaxed mb-4" style="color:#F0F0F5;">
              "{t.text}"
            </blockquote>

            <footer style="border-top:1px solid rgba(255,255,255,0.06);padding-top:1rem;">
              <cite class="not-italic">
                <p class="font-bold text-sm text-text">{t.name}</p>
                <p class="text-xs mt-0.5" style="color:#8892A4;">{t.destination} — {t.date}</p>
              </cite>
            </footer>
          </article>
        ))}
      </div>
    </div>
  </section>
) : (
  <section id="testemunhos" class="hidden" aria-hidden="true">
    <!-- Testemunhos: secção oculta enquanto não houver dados -->
  </section>
)}
