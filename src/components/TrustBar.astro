---
// FR-02: Trust Bar — glassmorphism dark
---

<section id="trust-bar" aria-label="Indicadores de confiança">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <div class="glass rounded-2xl py-5 px-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">

        <!-- RNAVT -->
        <div class="reveal reveal-delay-1 flex items-center gap-3 justify-center md:justify-start">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(245,166,35,0.12);border:1px solid rgba(245,166,35,0.25);">
            <svg class="w-5 h-5" style="color:#F5A623;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-sm text-text">RNAVT N.12366</p>
            <p class="text-xs" style="color:#8892A4;">Agência licenciada</p>
          </div>
        </div>

        <!-- Viagens organizadas -->
        <div class="reveal reveal-delay-2 flex items-center gap-3 justify-center md:justify-start">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(0,212,170,0.12);border:1px solid rgba(0,212,170,0.25);">
            <svg class="w-5 h-5" style="color:#00D4AA;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-sm text-text">Centenas de viagens</p>
            <p class="text-xs" style="color:#8892A4;">Organizadas com sucesso</p>
          </div>
        </div>

        <!-- Resposta 24h -->
        <div class="reveal reveal-delay-3 flex items-center gap-3 justify-center md:justify-start">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(245,166,35,0.12);border:1px solid rgba(245,166,35,0.25);">
            <svg class="w-5 h-5" style="color:#F5A623;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-sm text-text">Resposta em 24h</p>
            <p class="text-xs" style="color:#8892A4;">Atendimento rápido</p>
          </div>
        </div>

        <!-- Pagamento flexível -->
        <div class="reveal reveal-delay-4 flex items-center gap-3 justify-center md:justify-start">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background:rgba(0,212,170,0.12);border:1px solid rgba(0,212,170,0.25);">
            <svg class="w-5 h-5" style="color:#00D4AA;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div>
            <p class="font-bold text-sm text-text">Pagamento flexível</p>
            <p class="text-xs" style="color:#8892A4;">Multibanco · MB WAY · Transferência</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>
