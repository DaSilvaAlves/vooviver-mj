    text-transform: uppercase;
  }

  /* === SIDEBAR === */
  .bb-sidebar {
    position: fixed;
    top: 92px;
    left: 0;
    bottom: 0;
    width: 280px;
    background: var(--bg);
    border-right: 1px solid var(--glass-border);
    overflow-y: auto;
    padding: 1.5rem 0;
    z-index: 90;
  }

  .bb-sidebar-group-label {
    padding: 0.8rem 1.5rem 0.4rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--grey2);
    text-transform: uppercase;
  }

  .bb-sidebar-group-label:first-child {
    padding-top: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--grey);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--white);
    background: rgba(255,255,255,0.03);
    border-left-color: var(--gold);
  }

  .sidebar-link.active {
    color: var(--gold);
    background: rgba(245,166,35,0.08);
    border-left-color: var(--gold);
    font-weight: 700;
  }

  .sidebar-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    color: var(--grey2);
    width: 24px;
    text-align: right;
    flex-shrink: 0;
  }

  .sidebar-link.active .sidebar-num {
    color: var(--gold);
  }

  /* === MAIN CONTENT === */
  .bb-main {
    margin-left: 280px;
    margin-top: 92px;
    padding: 3rem 3rem 6rem;
    min-height: 100vh;
  }

  .bb-section {
    margin-bottom: 5rem;
    max-width: 800px;
  }

  /* Override content-section max-width for the new layout */
  .bb-main .content-section {
    max-width: 800px;
    padding: 0;
  }

  /* === SCROLLBAR (sidebar) === */
  .bb-sidebar::-webkit-scrollbar {
    width: 4px;
  }

  .bb-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .bb-sidebar::-webkit-scrollbar-thumb {
    background: var(--glass-border);
    border-radius: 2px;
  }

  .bb-sidebar::-webkit-scrollbar-thumb:hover {
    background: var(--grey2);
  }

  /* === PRINT MEDIA === */
  @media print {
    .bb-header,
    .bb-subtitle-bar,
    .bb-sidebar {
      display: none !important;
    }

    .bb-main {
      margin-left: 0 !important;
      margin-top: 0 !important;
      padding: 0 !important;
    }

    .bb-section {
      max-width: 100%;
      page-break-inside: avoid;
    }
  }

  /* === RESPONSIVE === */
  @media (max-width: 1024px) {
    .bb-sidebar {
      display: none;
    }

    .bb-main {
      margin-left: 0;
    }

    .bb-header-nav {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const sidebarLinks = document.querySelectorAll('.sidebar-link');
    const tabs = document.querySelectorAll('.bb-tab');
    const sections = document.querySelectorAll('.bb-section');

    // Section to group mapping
    const sectionGroups: Record<string, string> = {
      s01: 'marca', s02: 'marca',
      s03: 'estrategia', s04: 'estrategia', s05: 'estrategia', s06: 'estrategia',
      s07: 'identidade', s08: 'identidade', s09: 'identidade', s10: 'identidade',
      s11: 'logo', s12: 'logo',
      s13: 'aplicacao', s14: 'aplicacao', s15: 'aplicacao', s16: 'aplicacao',
    };

    // Scroll spy
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;

          // Update sidebar links
          sidebarLinks.forEach(link => link.classList.remove('active'));
          const activeLink = document.querySelector(`.sidebar-link[href="#${id}"]`);
          if (activeLink) activeLink.classList.add('active');

          // Update header tabs
          const group = sectionGroups[id];
          if (group) {
            tabs.forEach(tab => tab.classList.remove('active'));
            const activeTab = document.querySelector(`.bb-tab[data-group="${group}"]`);
            if (activeTab) activeTab.classList.add('active');
          }
        }
      });
    }, { rootMargin: '-100px 0px -60% 0px' });

    sections.forEach(section => observer.observe(section));

    // Smooth scroll on sidebar link click
    sidebarLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const href = link.getAttribute('href');
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });

    // Smooth scroll on tab click
    tabs.forEach(tab => {
      tab.addEventListener('click', (e) => {
        e.preventDefault();
        const href = tab.getAttribute('href');
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  });
</script>
