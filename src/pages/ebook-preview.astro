  <div class="content-section">
    <h3 class="chapter-subtitle">Vacinas — O Que e Obrigatório e O Que e Recomendado</h3>

    <table class="no-break">
      <thead>
        <tr>
          <th>Vacina</th>
          <th>Obrigatória para</th>
          <th>Recomendada para</th>
          <th>Onde fazer</th>
          <th>Custo</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Febre Amarela</td><td>Uganda, Ruanda</td><td>África subsariana</td><td>Centro de Vacinação Internacional</td><td>Gratuita (SNS)</td></tr>
        <tr><td>Hepatite A</td><td>—</td><td>África, Ásia, America Latina</td><td>Centro de saúde</td><td>Gratuita (SNS)</td></tr>
        <tr><td>Hepatite B</td><td>—</td><td>Todos os destinos</td><td>Centro de saúde</td><td>Gratuita (SNS)</td></tr>
        <tr><td>Febre Tifoide</td><td>—</td><td>India, África, Sudeste Asiático</td><td>Centro de Vacinação Internacional</td><td class="price">~20-40 EUR</td></tr>
