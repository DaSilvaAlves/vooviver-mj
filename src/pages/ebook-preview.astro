      <div style="display:flex;justify-content:space-between;align-items:flex-start;">
        <h3 style="margin-top:0;">2. Uganda e Ruanda — Gorilas de Montanha</h3>
        <span class="badge badge-teal">DISPONÍVEL</span>
      </div>
      <div class="destination-meta">
